class Database:
    def __init__(self, config: Config):
        self.config = config
        self.connection = None
        self.connect()

    def connect(self):
        try:
            self.connection = sqlite3.connect(self.config.db_path)
            self.connection.row_factory = sqlite3.Row
            self.connection.execute("PRAGMA foreign_keys = ON")
            logger.info(f"Успешное подключение к БД: {self.config.db_path}")
        except Exception as e:
            logger.error(f"Ошибка подключения к БД: {e}")
            raise

    def execute_query(self, query: str, params: tuple = None, fetch: bool = True):
        try:
            if self.connection is None:
                self.connect()
            cursor = self.connection.cursor()
            cursor.execute(query, params or ())
            if fetch:
                if query.strip().upper().startswith('SELECT'):
                    result = cursor.fetchall()
                    return [dict(row) for row in result] if result else []
                elif query.strip().upper().startswith('INSERT'):
                    self.connection.commit()
                    return {'lastrowid': cursor.lastrowid} if cursor.lastrowid else None
                else:
                    self.connection.commit()
                    return {'rowcount': cursor.rowcount} if cursor.rowcount > 0 else None
            else:
                self.connection.commit()
                return None
        except Exception as e:
            logger.error(f"Ошибка выполнения запроса: {e}")
            if self.connection:
                self.connection.rollback()
            raise

    def get_or_create_user(self, user_data: Dict) -> Dict:
        check_query = "SELECT * FROM users WHERE user_id = ?"
        existing_user = self.execute_query(check_query, (user_data['user_id'],))

        if existing_user:
            update_query = """
            UPDATE users 
            SET username = ?, first_name = ?, last_name = ?, registered_at = CURRENT_TIMESTAMP
            WHERE user_id = ?
            """
            self.execute_query(update_query, (
                user_data.get('username'),
                user_data.get('first_name'),
                user_data.get('last_name'),
                user_data['user_id']
            ), fetch=False)
            return self.execute_query(check_query, (user_data['user_id'],))[0]
        else:
            insert_query = """
            INSERT INTO users (user_id, username, first_name, last_name, registered_at)
            VALUES (?, ?, ?, ?, CURRENT_TIMESTAMP)
            """
            self.execute_query(insert_query, (
                user_data['user_id'],
                user_data.get('username'),
                user_data.get('first_name'),
                user_data.get('last_name')
            ), fetch=False)
            return self.execute_query(check_query, (user_data['user_id'],))[0]

    def get_types_of_specialties(self) -> List[Dict]:
        query = "SELECT * FROM types_of_specialties ORDER BY name"
        return self.execute_query(query)

    def get_specialties_by_type(self, type_id: int) -> List[Dict]:
        query = """
        SELECT s.*, t.name as type_name
        FROM specialties s
        LEFT JOIN types_of_specialties t ON s.tos_id = t.tos_id
        WHERE s.tos_id = ?
        ORDER BY s.code
        """
        return self.execute_query(query, (type_id,))

    def get_documents(self) -> List[Dict]:
        query = "SELECT * FROM documents ORDER BY priority, name"
        return self.execute_query(query)

    def get_dormitory_prices(self) -> List[Dict]:
        query = "SELECT * FROM dormitory ORDER BY price_per_month"
        return self.execute_query(query)

    def get_dormitory_addresses(self) -> List[Dict]:
        query = "SELECT address_id, address, phone_number FROM dormitory_addresses ORDER BY address"
        return self.execute_query(query)

    def get_educators_by_address(self) -> Dict[str, List[Dict]]:
        query = """
        SELECT e.*, p.name as position_name, da.address as dormitory_address, da.phone_number as dormitory_phone
        FROM educators e
        LEFT JOIN positions p ON e.position_id = p.position_id
        LEFT JOIN dormitory_addresses da ON e.address_id = da.address_id
        WHERE da.address IS NOT NULL
        ORDER BY da.address, p.name, e.full_name
        """
        educators = self.execute_query(query)
        grouped = {}
        for educator in educators:
            if educator:
                address = educator.get('dormitory_address')
                if address is None:
                    address = 'Не указан адрес'
                if address not in grouped:
                    grouped[address] = []
                grouped[address].append(educator)
        return grouped

    def get_important_dates(self, limit: int = 20) -> List[Dict]:
        query = "SELECT * FROM important_dates ORDER BY date_value LIMIT ?"
        return self.execute_query(query, (limit,))

    def get_contacts(self) -> List[Dict]:
        query = "SELECT * FROM contacts ORDER BY priority"
        return self.execute_query(query)

    def get_link_type_by_name(self, type_name: str) -> Optional[Dict]:
        query = "SELECT * FROM link_types WHERE name = ?"
        result = self.execute_query(query, (type_name,))
        return result[0] if result else None

    def get_links_by_type_id(self, type_id: int) -> List[Dict]:
        query = """
        SELECT l.*, lt.name as type_name
        FROM links l
        LEFT JOIN link_types lt ON l.link_type_id = lt.link_type_id
        WHERE l.link_type_id = ?
        ORDER BY l.name
        """
        return self.execute_query(query, (type_id,))

    def get_all_links(self) -> List[Dict]:
        query = """
        SELECT l.*, lt.name as type_name
        FROM links l
        LEFT JOIN link_types lt ON l.link_type_id = lt.link_type_id
        ORDER BY lt.name, l.name
        """
        return self.execute_query(query)

    def get_sports_activities(self) -> List[Dict]:
        query = """
        SELECT sa.sa_id, sa.name, sa.venue_id, v.name as venue_name 
        FROM sports_activities sa
        LEFT JOIN venues v ON sa.venue_id = v.venue_id
        ORDER BY sa.name
        """
        return self.execute_query(query)

    def get_venues(self) -> List[Dict]:
        query = "SELECT venue_id, name FROM venues ORDER BY name"
        return self.execute_query(query)

    def get_activities_by_venue(self) -> Dict[str, List[Dict]]:
        activities = self.get_sports_activities()
        grouped = {}
        for activity in activities:
            venue_name = activity.get('venue_name', 'Без площадки')
            if venue_name not in grouped:
                grouped[venue_name] = []
            grouped[venue_name].append(activity)
        return grouped

    def close(self):
        if self.connection:
            self.connection.close()
            logger.info("Соединение с БД закрыто")

class AdmissionsBot:
    def __init__(self, token: str, db: Database, admin_ids: List[int], config: Config):
        self.bot = Bot(token=token)
        self.db = db
        self.admin_ids = admin_ids
        self.config = config
        self.dp = Dispatcher()
        self.register_handlers()

    def register_handlers(self):
        @self.dp.bot_started()
        async def on_bot_started(event: BotStarted):
            await self.handle_bot_started(event)
        @self.dp.message_created(Command('start'))
        async def on_start(event: MessageCreated):
            await self.handle_start(event)
        @self.dp.message_created(Command('admin'))
        async def on_admin(event: MessageCreated):
            await self.handle_admin(event)
        @self.dp.callback_query()
        async def on_callback(event: CallbackQuery):
            await self.handle_callback(event)

    async def handle_bot_started(self, event: BotStarted):
        await event.bot.send_message(
            chat_id=event.chat_id,
            text="👋 Добро пожаловать в бот приемной комиссии!\n\nОтправьте /start для начала работы."
        )

    async def handle_start(self, event: MessageCreated):
        """Обработчик команды /start"""
        user_data = {
            'user_id': event.message.from_user.id,
            'username': event.message.from_user.username,
            'first_name': event.message.from_user.first_name,
            'last_name': event.message.from_user.last_name
        }
        self.db.get_or_create_user(user_data)
        await self.show_main_menu(event)

    async def handle_admin(self, event: MessageCreated):
        """Обработчик команды /admin"""
        if event.message.from_user.id not in self.admin_ids:
            await event.message.answer("⛔ У вас нет прав администратора.")
            return
        
        users_result = self.db.execute_query("SELECT COUNT(*) as count FROM users")
        specs_result = self.db.execute_query("SELECT COUNT(*) as count FROM specialties")
        contacts_result = self.db.execute_query("SELECT COUNT(*) as count FROM contacts")
        users_count = users_result[0]['count'] if users_result else 0
        specs_count = specs_result[0]['count'] if specs_result else 0
        contacts_count = contacts_result[0]['count'] if contacts_result else 0
        stats_text = f"""
👑 *Панель администратора*

📊 Статистика:
👥 Пользователей: {users_count}
🎓 Специальностей: {specs_count}
📞 Контактов: {contacts_count}
        """
        keyboard = {
            "inline_keyboard": [
                [{"text": "📊 Подробная статистика", "callback_data": "admin_stats"}],
                [{"text": "🏠 Главное меню", "callback_data": "main_menu"}]
            ]
        }
        await event.message.answer(stats_text, parse_mode="Markdown", reply_markup=keyboard)

