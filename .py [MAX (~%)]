        data = event.data
        try:
            if data == "main_menu":
                # Создаем фиктивный MessageCreated для show_main_menu
                await self.show_main_menu(callback_query=event)
            elif data == "menu_specialties":
                await self.show_specialties_menu(event)
            elif data == "menu_dormitory":
                await self.show_dormitory_menu(event)
            elif data == "menu_schedule":
                await self.show_schedule_menu(event)
            elif data == "menu_contacts":
                await self.show_contacts_menu(event)
            elif data == "menu_dates":
                await self.show_dates_menu(event)
            elif data == "menu_rules":
                await self.show_rules_menu(event)
            elif data == "menu_become_student":
                await self.show_become_student_menu(event)
            elif data == "menu_activities":
                await self.show_activities_menu(event)
            elif data.startswith("type_"):
                type_id = int(data.split("_")[1])
                await self.show_specialties_by_type(event, type_id)
            elif data == "admin_stats":
                if event.from_user.id not in self.admin_ids:
                    await event.message.edit_text("⛔ У вас нет прав администратора.")
                    return
                users = self.db.execute_query("SELECT * FROM users")
                specialties = self.db.execute_query("SELECT * FROM specialties")
                dates = self.db.execute_query("SELECT * FROM important_dates")
                documents = self.db.execute_query("SELECT * FROM documents")
                contacts = self.db.execute_query("SELECT * FROM contacts")
                types = self.db.get_types_of_specialties()
                stats_text = f"""
*Статистика бота:*

👥 Пользователей: {len(users)}
🎓 Специальностей: {len(specialties)}
📅 Важных дат: {len(dates)}
📄 Документов: {len(documents)}
📞 Контактов: {len(contacts)}
📚 Типов специальностей: {len(types)}
                """
                keyboard = {
                    "inline_keyboard": [
                        [{"text": "🔙 Назад", "callback_data": "main_menu"}]
                    ]
                }
                await event.message.edit_text(stats_text, parse_mode="Markdown", reply_markup=keyboard)
            else:
                await event.answer("Действие не распознано", show_alert=True)
        except Exception as e:
            logger.error(f"Ошибка обработки callback: {e}")
            await event.message.edit_text(
                "❌ Произошла ошибка. Попробуйте еще раз.",
                reply_markup={"inline_keyboard": [[{"text": "🏠 Главное меню", "callback_data": "main_menu"}]]}
            )
        await event.answer()  # Подтверждаем получение callback

    async def start(self):
        """Запуск бота"""
        logger.info("Запуск бота для Max...")
        try:
            specialties = self.db.execute_query("SELECT COUNT(*) as count FROM specialties")
            types = self.db.get_types_of_specialties()
            links = self.db.get_all_links()
            specs_count = specialties[0]['count'] if specialties else 0
            print("\n" + "=" * 30)
            print("Бот для Max успешно запущен!")
            print(f"Специальностей в базе: {specs_count}")
            print(f"Типов специальностей: {len(types)}")
            print(f"Ссылок в базе: {len(links)}")
            print("=" * 30 + "\n")
        except Exception as e:
            logger.error(f"❌ Ошибка проверки БД: {e}")
            print(f"\n❌ Ошибка подключения к БД: {e}")
            return
        await self.dp.start_polling(self.bot)

def main():
    print("=" * 30)
    print("БОТ ПРИЕМНОЙ КОМИССИИ ДЛЯ MAX")
    print("=" * 30)
    config = Config()
    try:
        db = Database(config)
        bot = AdmissionsBot(config.bot_token, db, config.admin_ids, config)
        print("\nЗапускаю бота...")
        asyncio.run(bot.start())
    except Exception as e:
        print(f"\nОШИБКА ПРИ ЗАПУСКЕ: {e}")
        print("\nВозможные причины:")
        print("1. Отсутствует файл базы данных admissions_bot.db")
        print("2. Неправильный токен бота для Max")
        print("3. Проблемы с подключением к Max API")
    finally:
        if 'db' in locals():
            db.close()

if __name__ == "__main__":
    main()
