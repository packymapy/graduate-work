        rows = keyboard.inline_keyboard.copy()
        rows.append([InlineKeyboardButton(text="🔙 Назад", callback_data="main_menu")])
        return InlineKeyboardMarkup(inline_keyboard=rows)

    async def callback_handler(self, callback_query: CallbackQuery):
        data = callback_query.data
        await callback_query.answer()
        try:
            if data == "main_menu":
                await self.show_main_menu(callback_query=callback_query)
            elif data == "menu_specialties":
                await self.show_specialties_menu(callback_query)
            elif data == "menu_dormitory":
                await self.show_dormitory_menu(callback_query)
            elif data == "menu_schedule":
                await self.show_schedule_menu(callback_query)
            elif data == "menu_contacts":
                await self.show_contacts_menu(callback_query)
            elif data == "menu_dates":
                await self.show_dates_menu(callback_query)
            elif data == "menu_rules":
                await self.show_rules_menu(callback_query)
            elif data == "menu_become_student":
                await self.show_become_student_menu(callback_query)
            elif data == "menu_activities":
                await self.show_activities_menu(callback_query)
            elif data.startswith("type_"):
                type_id = int(data.split("_")[1])
                await self.show_specialties_by_type(callback_query, type_id)
            elif data == "admin_stats":
                if callback_query.from_user.id not in self.admin_ids:
                    await callback_query.message.edit_text("⛔ У вас нет прав администратора.")
                    return
                users = self.db.execute_query("SELECT * FROM users")
                specialties = self.db.execute_query("SELECT * FROM specialties")
                dates = self.db.execute_query("SELECT * FROM important_dates")
                documents = self.db.execute_query("SELECT * FROM documents")
                contacts = self.db.execute_query("SELECT * FROM contacts")
                types = self.db.get_types_of_specialties()
                educators = self.db.get_educators_by_address()
                links = self.db.get_all_links()
                activities = self.db.get_sports_activities()
                venues = self.db.get_venues()
                total_educators = sum(len(edu_list) for edu_list in educators.values()) if educators else 0
                total_addresses = len(educators) if educators else 0
                stats_text = f"""
*Статистика бота:*

👥 Пользователей: {len(users)}
🎓 Специальностей: {len(specialties)}
📅 Важных дат: {len(dates)}
📄 Документов: {len(documents)}
📞 Контактов: {len(contacts)}
📚 Типов специальностей: {len(types)}
👩‍🏫 Воспитателей: {total_educators} (в {total_addresses} адресах)
🔗 Ссылок: {len(links)}
🏟️ Площадок: {len(venues)}
⚽ Активностей: {len(activities)}
                """
                keyboard = InlineKeyboardMarkup(inline_keyboard=[
                    [InlineKeyboardButton(text="🔙 Назад", callback_data="admin_back")],
                    [InlineKeyboardButton(text="🏠 Главное меню", callback_data="main_menu")]
                ])
                await callback_query.message.edit_text(stats_text, parse_mode="Markdown", reply_markup=keyboard)
            elif data == "admin_back":
                await self.admin_command(callback_query.message)
            else:
                await callback_query.answer("Действие не распознано", show_alert=True)
        except Exception as e:
            logger.error(f"Ошибка обработки callback: {e}")
            await callback_query.message.edit_text(
                "❌ Произошла ошибка. Попробуйте еще раз.",
                reply_markup=InlineKeyboardMarkup(inline_keyboard=[
