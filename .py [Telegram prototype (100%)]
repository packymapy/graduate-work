    def get_link_types(self) -> List[Dict]:
        query = "SELECT * FROM link_types ORDER BY name"
        return self.execute_query(query)

    def get_venues(self) -> List[Dict]:
        query = "SELECT venue_id, name FROM venues ORDER BY name"
        return self.execute_query(query)

    def get_sports_activities(self) -> List[Dict]:
        query = """
        SELECT sa.sa_id, sa.name, sa.venue_id, v.name as venue_name 
        FROM sports_activities sa
        LEFT JOIN venues v ON sa.venue_id = v.venue_id
        ORDER BY sa.name
        """
        return self.execute_query(query)

    def get_activities_by_venue(self) -> Dict[str, List[Dict]]:
        activities = self.get_sports_activities()
        grouped = {}

        for activity in activities:
            venue_name = activity.get('venue_name', 'Без площадки')
            if venue_name not in grouped:
                grouped[venue_name] = []
            grouped[venue_name].append(activity)
        return grouped

    def close(self):
        if self.connection:
            self.connection.close()
            logger.info("Соединение с базой данных закрыто")

