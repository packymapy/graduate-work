class AdmissionsBot:
    def __init__(self, token: str, db: Database, admin_ids: List[int], config: Config):
        self.bot = Bot(token=token)
        self.db = db
        self.admin_ids = admin_ids
        self.config = config
        self.storage = MemoryStorage()
        self.dp = Dispatcher(storage=self.storage)
        self.router = Router()
        self.dp.include_router(self.router)
        self.register_handlers()

    def register_handlers(self):
        self.router.message.register(self.start_command, CommandStart())
        self.router.message.register(self.admin_command, Command("admin"))
        self.router.callback_query.register(self.callback_handler)

    async def start_command(self, message: Message):
        user_data = {
            'user_id': message.from_user.id,
            'username': message.from_user.username,
            'first_name': message.from_user.first_name,
            'last_name': message.from_user.last_name
        }
        self.db.get_or_create_user(user_data)
        await self.show_main_menu(message)

