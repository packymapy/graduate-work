CREATE TABLE IF NOT EXISTS users (
    user_id INTEGER PRIMARY KEY,
    first_name TEXT NOT NULL,
    last_name TEXT,
    registered_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS certificate_orders (
    order_id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER NOT NULL,
    student_full_name TEXT NOT NULL,
    student_group TEXT,
    certificate_type TEXT NOT NULL,
    student_message TEXT,
    status TEXT DEFAULT 'new',
    order_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    processed_date TIMESTAMP,
    admin_comment TEXT,
    FOREIGN KEY (user_id) REFERENCES users(user_id) ON DELETE CASCADE
);

CREATE TABLE IF NOT EXISTS types_of_specialties (
    tos_id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL UNIQUE
);

CREATE TABLE IF NOT EXISTS specialties (
    spec_id INTEGER PRIMARY KEY AUTOINCREMENT,
    tos_id INTEGER NOT NULL,
    code TEXT NOT NULL,
    name TEXT NOT NULL,
    description TEXT,
    duration_years INTEGER,
    budget_places INTEGER DEFAULT 0,
    paid_places INTEGER DEFAULT 0,
    price_per_year INTEGER DEFAULT 0,
    FOREIGN KEY (tos_id) REFERENCES types_of_specialties(tos_id) ON DELETE CASCADE
);

CREATE TABLE IF NOT EXISTS documents (
    doc_id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    description TEXT,
    is_required BOOLEAN DEFAULT 1,
    priority INTEGER DEFAULT 0
);

CREATE TABLE IF NOT EXISTS dormitory (
    dorm_id INTEGER PRIMARY KEY AUTOINCREMENT,
    type_places TEXT NOT NULL,
    price_per_month INTEGER DEFAULT 0
);

CREATE TABLE IF NOT EXISTS contacts (
    contact_id INTEGER PRIMARY KEY AUTOINCREMENT,
    phone TEXT,
    email TEXT,
    address TEXT,
    working_hours TEXT,
    priority INTEGER DEFAULT 0
);

CREATE TABLE IF NOT EXISTS important_dates (
    date_id INTEGER PRIMARY KEY AUTOINCREMENT,
    title TEXT NOT NULL,
    date_value DATE NOT NULL,
    description TEXT
);

CREATE TABLE IF NOT EXISTS links (
    link_id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    url TEXT NOT NULL,
    priority INTEGER DEFAULT 0
);

CREATE TABLE IF NOT EXISTS sports_activities (
    sa_id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    description TEXT,
    schedule TEXT
);


CREATE INDEX IF NOT EXISTS idx_certificate_orders_user_id ON certificate_orders(user_id);
CREATE INDEX IF NOT EXISTS idx_certificate_orders_status ON certificate_orders(status);
CREATE INDEX IF NOT EXISTS idx_certificate_orders_order_date ON certificate_orders(order_date);
CREATE INDEX IF NOT EXISTS idx_specialties_tos_id ON specialties(tos_id);


