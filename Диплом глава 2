2.3.6 Панель администратора и управление статусами заказов
Важной особенностью разработанного бота является панель администратора, позволяющая управлять заказами справок. Администратор может просматривать заказы с фильтрацией по статусу, изменять статус заказа, добавлять комментарии и удалять заказы. При изменении статуса пользователь автоматически получает уведомление.
Фрагмент кода - изменение статуса заказа с уведомлением:

async def update_order_status_with_notification(self, event: MessageCreated, order_id: int, new_status: str = None, comment: str = None):
order = self.db.get_order_by_id(order_id)
if not order:
await event.message.answer("Заказ не найден.")
return False
success = self.db.update_order_status(order_id, new_status, comment)
if success:
if new_status:
status_display = self.STATUS_DISPLAY[new_status]
await event.message.answer(f"✅ Статус заказа #{order_id} изменен на '{status_display}'")
try:
notification_text = f"""
📢 ИЗМЕНЕНИЕ СТАТУСА ЗАКАЗА #{order_id}

📄 Тип: {order['certificate_type']}
🔄 Новый статус: {status_display}
📅 Время: {datetime.now().strftime('%d.%m.%Y %H:%M')}
"""
if comment:
notification_text += f"\n💬 Комментарий администратора:\n{comment}\n"
if new_status == self.STATUS_READY:
notification_text += "\n📎 Справка готова к выдаче! Обратитесь в учебный отдел."
await event.bot.send_message(
chat_id=order['user_id'],
text=notification_text)
except Exception as e:
logger.error(f"Не удалось отправить уведомление: {e}")
else:
await event.message.answer(f"✅ Комментарий добавлен к заказу #{order_id}")
return True
await event.message.answer("❌ Не удалось изменить статус заказа.")
return False


