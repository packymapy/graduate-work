В данном фрагменте кода запрашивается ФИО студента. Одновременно с этим бот получает информацию о внутреннем идентификаторе пользователя в Макс.

2) async def handle_message(self, event: MessageCreated):
    user_id = event.message.from_user.id
    text = event.message.text
    if user_id in self.user_states:
        state = self.user_states[user_id]
        if state['action'] == 'waiting_full_name':
            self.user_states[user_id]['full_name'] = text
            self.user_states[user_id]['action'] = 'waiting_certificate_type'
            keyboard = {
                "inline_keyboard": [
                    [{"text": "📄 Справка об обучении", "callback_data": "cert_type_обучении"}],
                    [{"text": "📊 Академическая справка", "callback_data": "cert_type_академическая"}],
                    [{"text": "💳 Справка для социальной стипендии", "callback_data": "cert_type_социальная"}],
                    [{"text": "🏥 Справка о состоянии здоровья", "callback_data": "cert_type_здоровье"}],
                    [{"text": "📝 Другая справка", "callback_data": "cert_type_другая"}],
                    [{"text": "🔙 Отмена", "callback_data": "cancel_order"}]
                ]
            }
            await event.message.answer("📋 *Выберите тип справки:*", parse_mode="Markdown", reply_markup=keyboard)
        elif state['action'] == 'waiting_other_certificate':
            student_message = text
            await self.save_and_notify_order(
                event, 
                state['full_name'], 
                "Другая справка", 
                student_message
            )
            del self.user_states[user_id]
В этом фрагменте идет обработка введенных данных пользователем, после чего предлагаются основные справки для заказа. Если пользователь не находит нужную, можно написать вручную, нажав на кнопку "Другая справка".

3) async def select_certificate_type(self, callback_query: CallbackQuery, cert_type: str):
    user_id = callback_query.from_user.id
    if user_id not in self.user_states or self.user_states[user_id]['action'] != 'waiting_certificate_type':
        await callback_query.answer("Пожалуйста, начните заказ заново", show_alert=True)
        await self.start_certificate_order(callback_query)
        return
    full_name = self.user_states[user_id]['full_name']
    if cert_type == "другая":
        self.user_states[user_id]['action'] = 'waiting_other_certificate'
        text = "Пожалуйста, напишите, какая именно справка вам нужна:"
        await callback_query.message.edit_text(text, parse_mode="Markdown")
    else:
        certificate_type_map = {
            "обучении": "Справка об обучении",
            "академическая": "Академическая справка",
            "социальная": "Справка для социальной стипендии",
            "здоровье": "Справка о состоянии здоровья"
        }
        certificate_type = certificate_type_map.get(cert_type, cert_type)
        class FakeMessage:
            def __init__(self, from_user, answer_func):
                self.from_user = from_user
                self.answer = answer_func
        class FakeEvent:
            def __init__(self, message, bot):
                self.message = message
                self.bot = bot
        fake_message = FakeMessage(callback_query.from_user, callback_query.message.edit_text)
        fake_event = FakeEvent(fake_message, callback_query.bot)
        await self.save_and_notify_order(fake_event, full_name, certificate_type)
        del self.user_states[user_id]
        await asyncio.sleep(3)
        await self.show_main_menu(callback_query=callback_query)
В этом фрагменте кода сохраняется выбранная справка, либо данные о ней. 

4) async def save_and_notify_order(self, event: MessageCreated, full_name: str, certificate_type: str, student_message: str = None):
    user_id = event.message.from_user.id
    order_id = self.db.save_certificate_order(user_id, full_name, certificate_type, student_message)
    if order_id:
        response_text = f"✅ *Заказ справки принят!*\n\n"
        response_text += f"Номер заказа: #{order_id}\n"
        response_text += f"Тип справки: {certificate_type}\n"
        if student_message:
            response_text += f"Ваше сообщение: {student_message}\n\n"
        response_text += f"Ожидайте, администратор свяжется с вами."
        await event.message.answer(response_text, parse_mode="Markdown")
        for admin_id in self.admin_ids:
            try:
                admin_text = f"🔔 *Новый заказ справки!*\n\n"
                admin_text += f"*Заказ #{order_id}*\n"
                admin_text += f"👤 Студент: {full_name}\n"
                admin_text += f"📱 ID: {user_id}\n"
                admin_text += f"📄 Тип справки: {certificate_type}\n"
                if student_message:
                    admin_text += f"💬 Сообщение: {student_message}\n"
                admin_text += f"🕐 Время: {datetime.now().strftime('%d.%m.%Y %H:%M')}\n\n"
                admin_text += f"Используйте /admin для просмотра всех заказов"
                await event.bot.send_message(
                    chat_id=admin_id,
                    text=admin_text,
                    parse_mode="Markdown"
                )
            except Exception as e:
                logger.error(f"Не удалось отправить уведомление админу {admin_id}: {e}")
    else:
        await event.message.answer("❌ Произошла ошибка при оформлении заказа. Попробуйте позже.")
Здесь представлена функция занесения заказа справки в базу с последующим уведомлением администратора. Пользователь может поменять данные, если ввел их неправильно. 
После подтверждения отправки сообщения пользователем, формируется сообщение, которое дойдет администратору бота.

