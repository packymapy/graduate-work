1) def get_or_create_user(self, user_data: Dict) -> Dict:
        check_query = "SELECT * FROM users WHERE user_id = ?"
        existing_user = self.execute_query(check_query, (user_data['user_id'],))
        if existing_user: current_user = existing_user[0] needs_update = False
            if current_user.get('first_name') != user_data.get('first_name'): needs_update = True
            if current_user.get('last_name') != user_data.get('last_name'): needs_update = True
            if needs_update:
                update_query = """UPDATE users SET first_name = ?, last_name = ?, updated_at = CURRENT_TIMESTAMP WHERE user_id = ?"""
                self.execute_query(update_query, (user_data.get('first_name'), user_data.get('last_name'), user_data['user_id']), fetch=False)
                logger.info(f"Данные пользователя {user_data['user_id']} обновлены")
            return self.execute_query(check_query, (user_data['user_id'],))[0]
        else:
            insert_query = """INSERT INTO users (user_id, first_name, last_name, registered_at, updated_at) VALUES (?, ?, ?, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP)"""
            self.execute_query(insert_query, (user_data['user_id'], user_data.get('first_name'), user_data.get('last_name')), fetch=False)
            logger.info(f"Создан новый пользователь {user_data['user_id']}")
            return self.execute_query(check_query, (user_data['user_id'],))[0]
