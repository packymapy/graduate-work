1) async def start_certificate_order(self, callback_query: CallbackQuery):
    user_id = callback_query.from_user.id
    self.user_states[user_id] = {
        'action': 'waiting_full_name',
        'chat_id': callback_query.message.chat.id}
    text = """
📄 *Заказ справки*
