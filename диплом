- 3.5 методы и их листинг
- - 3.5.1 обработчик callback-запросов
Метод handle_callback() является центральным маршрутизатором всех нажатий на inline-кнопки. Он обрабатывает более 15 типов callback_data:
async def handle_callback(self, event: CallbackQuery):
    data = event.data
    try:
        if data == "main_menu":
            await self.show_main_menu(callback_query=event)
        elif data == "menu_specialties":
            await self.show_specialties_menu(event)
        elif data.startswith("type_"):
            type_id = int(data.split("_")[1])
            await self.show_specialties_by_type(event, type_id)
        elif data.startswith("cert_type_"):
            cert_type = data.split("_")[2]
            await self.select_certificate_type(event, cert_type)
        elif data == "admin_mark_processed":
            await self.mark_orders_processed(event)
    except Exception as e:
        logger.error(f"Ошибка обработки callback: {e}")
        await event.message.edit_text("❌ Произошла ошибка.")

- - 3.5.2 метод «сохранить и оповестить», относящийся к справкам
Этот метод демонстрирует принцип атомарности операции — сохранение в БД и уведомление администраторов:
async def save_and_notify_order(self, event: MessageCreated, full_name: str, certificate_type: str):
    order_id = self.db.save_certificate_order(user_id, username, full_name, certificate_type)
    if order_id:
        await event.message.answer(f"✅ Заказ #{order_id} принят!")
        for admin_id in self.admin_ids:
            await event.bot.send_message(chat_id=admin_id, text=f"Новый заказ #{order_id}")
    else:
        await event.message.answer("❌ Ошибка при оформлении заказа.")

