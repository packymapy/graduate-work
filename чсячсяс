class Database:
    def __init__(self, config: Config):
        self.config = config
        self.connection = None
        self.connect()
        self.create_orders_table()

    def connect(self):
        try:
            self.connection = sqlite3.connect(self.config.db_path)
            self.connection.row_factory = sqlite3.Row
            self.connection.execute("PRAGMA foreign_keys = ON")
            logger.info(f"Успешное подключение к БД: {self.config.db_path}")
        except Exception as e:
            logger.error(f"Ошибка подключения к БД: {e}")
            raise

    def create_orders_table(self):
        """Создать таблицу для заказов справок"""
        query = """
        CREATE TABLE IF NOT EXISTS certificate_orders (
            order_id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            username TEXT,
            full_name TEXT NOT NULL,
            certificate_type TEXT NOT NULL,
            status TEXT DEFAULT 'new',
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            processed_at TIMESTAMP,
            admin_comment TEXT
        )
        """
        self.execute_query(query, fetch=False)
        logger.info("Таблица certificate_orders проверена/создана")

    def execute_query(self, query: str, params: tuple = None, fetch: bool = True):
        try:
            if self.connection is None:
                self.connect()
            cursor = self.connection.cursor()
            cursor.execute(query, params or ())
            if fetch:
                if query.strip().upper().startswith('SELECT'):
                    result = cursor.fetchall()
                    return [dict(row) for row in result] if result else []
                elif query.strip().upper().startswith('INSERT'):
                    self.connection.commit()
                    return {'lastrowid': cursor.lastrowid} if cursor.lastrowid else None
                else:
                    self.connection.commit()
                    return {'rowcount': cursor.rowcount} if cursor.rowcount > 0 else None
            else:
                self.connection.commit()
                return None
        except Exception as e:
            logger.error(f"Ошибка выполнения запроса: {e}")
            if self.connection:
                self.connection.rollback()
            raise

    def get_or_create_user(self, user_data: Dict) -> Dict:
        """Получить или создать пользователя с проверкой на дубликаты"""
        check_query = "SELECT * FROM users WHERE user_id = ?"
        existing_user = self.execute_query(check_query, (user_data['user_id'],))

        if existing_user:
            # Проверяем, изменились ли данные пользователя
            current_user = existing_user[0]
            needs_update = False
            
            # Сравниваем текущие данные с новыми
            if current_user.get('username') != user_data.get('username'):
                needs_update = True
            if current_user.get('first_name') != user_data.get('first_name'):
                needs_update = True
            if current_user.get('last_name') != user_data.get('last_name'):
                needs_update = True
            
            # Обновляем только если данные изменились
            if needs_update:
                update_query = """
                UPDATE users 
                SET username = ?, first_name = ?, last_name = ?, updated_at = CURRENT_TIMESTAMP
                WHERE user_id = ?
                """
                self.execute_query(update_query, (
                    user_data.get('username'),
                    user_data.get('first_name'),
                    user_data.get('last_name'),
                    user_data['user_id']
                ), fetch=False)
                logger.info(f"Данные пользователя {user_data['user_id']} обновлены")
            else:
                logger.info(f"Пользователь {user_data['user_id']} уже существует, данные актуальны")
            
            return self.execute_query(check_query, (user_data['user_id'],))[0]
        else:
            # Создаем нового пользователя
            insert_query = """
            INSERT INTO users (user_id, username, first_name, last_name, registered_at, updated_at)
            VALUES (?, ?, ?, ?, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP)
            """
            self.execute_query(insert_query, (
                user_data['user_id'],
                user_data.get('username'),
                user_data.get('first_name'),
                user_data.get('last_name')
            ), fetch=False)
            logger.info(f"Создан новый пользователь {user_data['user_id']}")
            return self.execute_query(check_query, (user_data['user_id'],))[0]

    def save_certificate_order(self, user_id: int, username: str, full_name: str, certificate_type: str) -> int:
        """Сохранить заказ справки"""
        query = """
        INSERT INTO certificate_orders (user_id, username, full_name, certificate_type, status)
        VALUES (?, ?, ?, ?, 'new')
        """
        result = self.execute_query(query, (user_id, username, full_name, certificate_type))
        return result['lastrowid'] if result else None

    def get_orders_by_status(self, status: str = 'new') -> List[Dict]:
        """Получить заказы по статусу"""
        query = """
        SELECT * FROM certificate_orders 
        WHERE status = ? 
        ORDER BY created_at DESC
        """
        return self.execute_query(query, (status,))

    def update_order_status(self, order_id: int, status: str, admin_comment: str = None):
        """Обновить статус заказа"""
        query = """
        UPDATE certificate_orders 
        SET status = ?, processed_at = CURRENT_TIMESTAMP, admin_comment = ?
        WHERE order_id = ?
        """
        self.execute_query(query, (status, admin_comment, order_id), fetch=False)

    def get_types_of_specialties(self) -> List[Dict]:
        query = "SELECT * FROM types_of_specialties ORDER BY name"
        return self.execute_query(query)

    def get_specialties_by_type(self, type_id: int) -> List[Dict]:
        query = """
        SELECT s.*, t.name as type_name
        FROM specialties s
        LEFT JOIN types_of_specialties t ON s.tos_id = t.tos_id
        WHERE s.tos_id = ?
        ORDER BY s.code
        """
        return self.execute_query(query, (type_id,))

    def get_documents(self) -> List[Dict]:
        query = "SELECT * FROM documents ORDER BY priority, name"
        return self.execute_query(query)

    def get_dormitory_prices(self) -> List[Dict]:
        query = "SELECT * FROM dormitory ORDER BY price_per_month"
        return self.execute_query(query)

    def get_dormitory_addresses(self) -> List[Dict]:
        query = "SELECT address_id, address, phone_number FROM dormitory_addresses ORDER BY address"
        return self.execute_query(query)

    def get_educators_by_address(self) -> Dict[str, List[Dict]]:
        query = """
        SELECT e.*, p.name as position_name, da.address as dormitory_address, da.phone_number as dormitory_phone
        FROM educators e
        LEFT JOIN positions p ON e.position_id = p.position_id
        LEFT JOIN dormitory_addresses da ON e.address_id = da.address_id
        WHERE da.address IS NOT NULL
        ORDER BY da.address, p.name, e.full_name
        """
        educators = self.execute_query(query)
        grouped = {}
        for educator in educators:
            if educator:
                address = educator.get('dormitory_address')
                if address is None:
                    address = 'Не указан адрес'
                if address not in grouped:
                    grouped[address] = []
                grouped[address].append(educator)
        return grouped

    def get_important_dates(self, limit: int = 20) -> List[Dict]:
        query = "SELECT * FROM important_dates ORDER BY date_value LIMIT ?"
        return self.execute_query(query, (limit,))

    def get_contacts(self) -> List[Dict]:
        query = "SELECT * FROM contacts ORDER BY priority"
        return self.execute_query(query)

    def get_link_type_by_name(self, type_name: str) -> Optional[Dict]:
        query = "SELECT * FROM link_types WHERE name = ?"
        result = self.execute_query(query, (type_name,))
        return result[0] if result else None

    def get_links_by_type_id(self, type_id: int) -> List[Dict]:
        query = """
        SELECT l.*, lt.name as type_name
        FROM links l
        LEFT JOIN link_types lt ON l.link_type_id = lt.link_type_id
        WHERE l.link_type_id = ?
        ORDER BY l.name
        """
        return self.execute_query(query, (type_id,))

    def get_links_by_type_name(self, type_name: str) -> List[Dict]:
        """Получить ссылки по названию типа"""
        query = """
        SELECT l.*, lt.name as type_name
        FROM links l
        LEFT JOIN link_types lt ON l.link_type_id = lt.link_type_id
        WHERE lt.name = ?
        ORDER BY l.name
        """
        return self.execute_query(query, (type_name,))

    def get_all_links(self) -> List[Dict]:
        query = """
        SELECT l.*, lt.name as type_name
        FROM links l
        LEFT JOIN link_types lt ON l.link_type_id = lt.link_type_id
        ORDER BY lt.name, l.name
        """
        return self.execute_query(query)

    def get_sports_activities(self) -> List[Dict]:
        query = """
        SELECT sa.sa_id, sa.name, sa.venue_id, v.name as venue_name 
        FROM sports_activities sa
        LEFT JOIN venues v ON sa.venue_id = v.venue_id
        ORDER BY sa.name
        """
        return self.execute_query(query)

    def get_venues(self) -> List[Dict]:
        query = "SELECT venue_id, name FROM venues ORDER BY name"
        return self.execute_query(query)

    def get_activities_by_venue(self) -> Dict[str, List[Dict]]:
        activities = self.get_sports_activities()
        grouped = {}
        for activity in activities:
            venue_name = activity.get('venue_name', 'Без площадки')
            if venue_name not in grouped:
                grouped[venue_name] = []
            grouped[venue_name].append(activity)
        return grouped

    def close(self):
        if self.connection:
            self.connection.close()
            logger.info("Соединение с БД закрыто")

class AdmissionsBot:
    def __init__(self, token: str, db: Database, admin_ids: List[int], config: Config):
        self.bot = Bot(token=token)
        self.db = db
        self.admin_ids = admin_ids
        self.config = config
        self.dp = Dispatcher()
        self.user_states = {}  # Для хранения состояний пользователей (ФИО, тип справки)
        self.register_handlers()

    def register_handlers(self):
        @self.dp.bot_started()
        async def on_bot_started(event: BotStarted):
            await self.handle_bot_started(event)
        @self.dp.message_created(Command('start'))
        async def on_start(event: MessageCreated):
            await self.handle_start(event)
        @self.dp.message_created(Command('admin'))
        async def on_admin(event: MessageCreated):
            await self.handle_admin(event)
        @self.dp.callback_query()
        async def on_callback(event: CallbackQuery):
            await self.handle_callback(event)
        @self.dp.message_created()
        async def on_message(event: MessageCreated):
            await self.handle_message(event)

    async def handle_bot_started(self, event: BotStarted):
        await event.bot.send_message(
            chat_id=event.chat_id,
            text="👋 Добро пожаловать в бот приемной комиссии!\n\nОтправьте /start для начала работы."
        )

    async def handle_start(self, event: MessageCreated):
        """Обработчик команды /start"""
        user_data = {
            'user_id': event.message.from_user.id,
            'username': event.message.from_user.username,
            'first_name': event.message.from_user.first_name,
            'last_name': event.message.from_user.last_name
        }
        self.db.get_or_create_user(user_data)
        await self.show_main_menu(event)

    async def handle_admin(self, event: MessageCreated):
        """Обработчик команды /admin - показывает новые заказы справок"""
        if event.message.from_user.id not in self.admin_ids:
            await event.message.answer("⛔ У вас нет прав администратора.")
            return
        
        # Получаем новые заказы
        new_orders = self.db.get_orders_by_status('new')
        
        if not new_orders:
            text = "📋 *Нет новых заказов справок*"
            keyboard = {
                "inline_keyboard": [
                    [{"text": "📜 Посмотреть обработанные", "callback_data": "admin_processed_orders"}],
                    [{"text": "🏠 Главное меню", "callback_data": "main_menu"}]
                ]
            }
        else:
            text = f"📋 *Новые заказы справок:* ({len(new_orders)})\n\n"
            for order in new_orders:
                text += f"*Заказ #{order['order_id']}*\n"
                text += f"👤 Студент: {order['full_name']}\n"
                if order['username']:
                    text += f"📱 Username: @{order['username']}\n"
                text += f"📄 Тип справки: {order['certificate_type']}\n"
                text += f"🕐 Создан: {order['created_at']}\n"
                text += f"➖➖➖➖➖➖➖➖➖\n"
            
            keyboard = {
                "inline_keyboard": [
                    [{"text": "✅ Отметить как выполненные", "callback_data": "admin_mark_processed"}],
                    [{"text": "📜 Посмотреть обработанные", "callback_data": "admin_processed_orders"}],
                    [{"text": "🏠 Главное меню", "callback_data": "main_menu"}]
                ]
            }
        
        await event.message.answer(text, parse_mode="Markdown", reply_markup=keyboard)

    async def handle_message(self, event: MessageCreated):
        """Обработка текстовых сообщений (для заказа справок)"""
        user_id = event.message.from_user.id
        text = event.message.text
        
        # Проверяем состояние пользователя
        if user_id in self.user_states:
            state = self.user_states[user_id]
            
            if state['action'] == 'waiting_full_name':
                # Сохраняем ФИО и запрашиваем тип справки
                self.user_states[user_id]['full_name'] = text
                self.user_states[user_id]['action'] = 'waiting_certificate_type'
                
                keyboard = {
                    "inline_keyboard": [
                        [{"text": "📄 Справка об обучении", "callback_data": "cert_type_обучении"}],
                        [{"text": "📊 Академическая справка", "callback_data": "cert_type_академическая"}],
                        [{"text": "💳 Справка для социальной стипендии", "callback_data": "cert_type_социальная"}],
                        [{"text": "🏥 Справка о состоянии здоровья", "callback_data": "cert_type_здоровье"}],
                        [{"text": "📝 Другая справка", "callback_data": "cert_type_другая"}],
                        [{"text": "🔙 Отмена", "callback_data": "cancel_order"}]
                    ]
                }
                await event.message.answer("📋 *Выберите тип справки:*", parse_mode="Markdown", reply_markup=keyboard)
                
            elif state['action'] == 'waiting_certificate_type':
                # Это уже обрабатывается в callback, но на всякий случай
                pass
            
            elif state['action'] == 'waiting_other_certificate':
                # Сохраняем другой тип справки
                certificate_type = f"Другое: {text}"
                await self.save_and_notify_order(event, state['full_name'], certificate_type)
                del self.user_states[user_id]
        
        # Игнорируем команды
        elif text.startswith('/'):
            pass

    async def save_and_notify_order(self, event: MessageCreated, full_name: str, certificate_type: str):
        """Сохранить заказ и уведомить администраторов"""
        user_id = event.message.from_user.id
        username = event.message.from_user.username
        
        # Сохраняем в БД
        order_id = self.db.save_certificate_order(user_id, username, full_name, certificate_type)
        
        if order_id:
            # Подтверждение пользователю
            await event.message.answer(
                f"✅ *Заказ справки принят!*\n\n"
                f"Номер заказа: #{order_id}\n"
                f"Тип справки: {certificate_type}\n\n"
                f"Ожидайте, администратор свяжется с вами.",
                parse_mode="Markdown"
            )
            
            # Уведомляем всех администраторов
            for admin_id in self.admin_ids:
                try:
                    admin_text = f"🔔 *Новый заказ справки!*\n\n"
                    admin_text += f"*Заказ #{order_id}*\n"
                    admin_text += f"👤 Студент: {full_name}\n"
                    admin_text += f"📱 ID: {user_id}\n"
                    if username:
                        admin_text += f"📱 Username: @{username}\n"
                    admin_text += f"📄 Тип справки: {certificate_type}\n"
                    admin_text += f"🕐 Время: {datetime.now().strftime('%d.%m.%Y %H:%M')}\n\n"
                    admin_text += f"Используйте /admin для просмотра всех заказов"
                    
                    await event.bot.send_message(
                        chat_id=admin_id,
                        text=admin_text,
                        parse_mode="Markdown"
                    )
                except Exception as e:
                    logger.error(f"Не удалось отправить уведомление админу {admin_id}: {e}")
        else:
            await event.message.answer("❌ Произошла ошибка при оформлении заказа. Попробуйте позже.")

