                def __init__(self, message, bot):
                    self.message = message
                    self.bot = bot
            
            fake_message = type('obj', (object,), {
                'from_user': callback_query.from_user,
                'answer': callback_query.message.edit_text
            })()
            fake_message.from_user = callback_query.from_user
            fake_message.from_user.username = callback_query.from_user.username
            
            fake_event = FakeEvent(fake_message, callback_query.bot)
            
            await self.save_and_notify_order(fake_event, full_name, certificate_type)
